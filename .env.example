# 复制为 .env 后修改：cp .env.example .env  (Linux)  或  copy .env.example .env  (Windows)

# MySQL root 密码（必填，请改为强密码）
MYSQL_ROOT_PASSWORD=ChangeMe_Strong_Password_123

# 数据库名
MYSQL_DATABASE=check_sec

# JWT 密钥（必填，至少 32 位随机字符串）
JWT_SECRET=PleaseChangeThisJwtSecretKeyToRandom32CharsOrMore

# 对外 HTTP 端口（默认 80，若占用可改为 8088 等）
HTTP_PORT=80
